{
  "name": "sshclient",
  "version": "0.1.0",
  "description": "A Termius-like SSH + SFTP client, built from scratch as a learning project",
  "main": "src/main/main.js",
  "scripts": {
    "test": "node --test test/*.test.js",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron . --dev",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build": "vite build",
    "start": "vite build && electron .",
    "dist:mac": "vite build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Vapourware-Studios",
  "license": "GPL-3.0-only",
  "build": {
    "appId": "net.vapourware-studios.sshclient",
    "productName": "SSH Client",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "icon": "build/icon.png"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.2.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.1.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "serialport": "^13.0.0",
    "simple-icons": "^16.26.0",
    "snappyjs": "^0.7.0",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.6.0",
    "tweetnacl": "^1.0.3"
  },
  "optionalDependencies": {
    "electron-liquid-glass": "^1.1.1"
  },
  "allowScripts": {
    "node-pty@1.1.0": true,
    "@serialport/bindings-cpp@13.0.0": true,
    "cpu-features@0.0.10": true
  }
}

{
  "name": "sshclient",
  "version": "0.1.0",
  "description": "A Termius-like SSH + SFTP client, built from scratch as a learning project",
  "main": "src/main/main.js",
  "scripts": {
    "start": "vite build && electron .",
    "dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && electron . --dev\"",
    "build": "vite build"
  },
  "author": "Vapourware-Studios",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.1.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  }
}
